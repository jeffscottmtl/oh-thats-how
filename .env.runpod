# ─────────────────────────────────────────────────────────────────────────────
# .env.runpod — RunPod CUDA overrides for the-signal
#
# Sourced AFTER .env by runpod_start.sh — values here win over .env.
# Keep your API keys in .env only; don't duplicate them here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Paths (pod uses /workspace instead of /Users/jeffscott/Downloads) ─────────
QWEN_TOOLS_ROOT=/workspace/the-signal
QWEN_PROFILE_MANIFEST=/workspace/the-signal/voice_profiles/jeff_v3/profile_manifest.csv

# ── Device: CUDA instead of Apple MPS ────────────────────────────────────────
QWEN3_TTS_DEVICE=cuda
QWEN3_TTS_DTYPE=float16
PYTORCH_ENABLE_MPS_FALLBACK=0

# ── Model weights: allow download on first run, then lock offline ─────────────
# After first run completes and weights are cached, flip these to 1
# to prevent any accidental network fetches mid-episode.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
