# Copy to .env locally if you use an env loader. Never commit real secrets.
OPENAI_API_KEY=
OPENAI_PROJECT_ID=
OPENAI_ORGANIZATION=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.35
ELEVENLABS_SIMILARITY_BOOST=0.8
ELEVENLABS_STYLE=0.55
ELEVENLABS_USE_SPEAKER_BOOST=true
ELEVENLABS_SPEED=1.0
TTS_PROVIDER=qwen
QWEN_PROFILE_MANIFEST=voice_profiles/jeff_v1/profile_manifest.csv
QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-Base
QWEN_REF_CLIP_ID=
QWEN_TTS_LANGUAGE=English
QWEN_TTS_INSTRUCT=Speak with warm confidence and natural conversational energy. Vary emphasis and pacing slightly for engagement.
QWEN_TTS_TEMPERATURE=0.72
QWEN_TTS_TOP_P=0.92
QWEN_TTS_TOP_K=45
QWEN_TTS_MAX_NEW_TOKENS=4096
QWEN_TTS_SPEED=1.0
QWEN_TTS_TIMEOUT_SECONDS=1800
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SCRIPT_MODEL=gpt-5.4
