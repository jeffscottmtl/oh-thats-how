{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "The Signal Script",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_name",
    "generated_at",
    "intro",
    "stories",
    "cn_relevance",
    "ending_segment",
    "food_for_thought",
    "word_count",
    "script_markdown",
    "rewrite_attempts",
    "explicit_fail_state"
  ],
  "properties": {
    "episode_name": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "intro": {"type": "string", "minLength": 1},
    "stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "title", "source_domain", "source_url", "published_at", "narrative"],
        "properties": {
          "index": {"type": "integer", "minimum": 1},
          "title": {"type": "string", "minLength": 1},
          "source_domain": {"type": "string", "minLength": 1},
          "source_url": {"type": "string", "minLength": 1},
          "published_at": {"type": ["string", "null"]},
          "narrative": {"type": "string", "minLength": 1}
        }
      }
    },
    "cn_relevance": {"type": ["string", "null"]},
    "ending_segment": {"type": "string", "minLength": 1},
    "food_for_thought": {"type": "string", "minLength": 1},
    "word_count": {"type": "integer", "minimum": 1},
    "script_markdown": {"type": "string", "minLength": 1},
    "rewrite_attempts": {"type": "integer", "minimum": 0, "maximum": 2},
    "explicit_fail_state": {"type": "boolean"}
  }
}
